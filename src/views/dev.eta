<% layout('layout.eta') %>
<h1>Developer Server</h1>
<p class="admin-context">Local development controls. Not part of the public registry and never available in production.</p>

<% if (it.seeded !== null) { %><p class="dev-status-ok"><%= it.seeded %> seeded.</p><% } %>
<% if (it.error !== null) { %><p class="dev-status-error">Seed action failed for “<%= it.error %>”. Check server logs.</p><% } %>

<h2>Environment</h2>
<dl class="record-metadata">
  <dt>NODE_ENV</dt><dd><%= it.env.nodeEnv %></dd>
  <dt>Host</dt><dd><%= it.env.host %>:<%= it.env.port %></dd>
  <dt>Database</dt><dd><%= it.env.databaseTarget %></dd>
  <dt>Node version</dt><dd><%= it.env.nodeVersion %></dd>
  <dt>Process ID</dt><dd><%= it.env.pid %></dd>
  <dt>Uptime</dt><dd><%= it.env.uptimeSeconds %>s</dd>
</dl>

<h2>Quick Links</h2>
<ul>
  <% it.quickLinks.forEach(function(link) { %><li><a href="<%= link.href %>"><%= link.label %></a></li><% }) %>
</ul>

<h2>Seed Data</h2>
<% if (it.databaseConfigured) { %>
<p>These call the existing <code>db:seed</code> functions directly. Both are additive and safe to re-run.</p>
<form class="status-form" method="post" action="/dev/seed/organizations">
  <button type="submit">Seed provider organizations</button>
</form>
<form class="status-form" method="post" action="/dev/seed/test-data">
  <button type="submit">Seed test fixture data</button>
</form>
<% } else { %>
<p>No database connection is configured for this server instance.</p>
<% } %>
