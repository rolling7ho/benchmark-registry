<% layout('layout.eta') %><%~ include('partials/breadcrumbs.eta', { items: it.breadcrumbs }) %><h1><%= it.benchmark.name %></h1><p class="page-summary"><%= it.description %></p><dl class="record-metadata"><dt>Benchmark Family</dt><dd><%= it.benchmark.name %></dd><dt>Organization</dt><dd><%= it.benchmark.organizationName ?? 'Unknown' %></dd><dt>Status</dt><dd><%= it.benchmark.status %></dd><dt>Records</dt><dd><%= it.benchmark.recordCount %></dd></dl>
<h2>Versions / Variants</h2><div class="table-scroll" tabindex="0" aria-label="Benchmark versions table"><table><thead><tr><th>Version or Variant</th><th>Reference</th><th>Status</th><th>Records</th></tr></thead><tbody><% it.benchmark.versions.forEach(function(version) { const segment = version.canonicalReference.split('/').slice(1).join('/'); %><tr><td><a href="/benchmarks/<%= encodeURIComponent(it.benchmark.slug) %>/versions/<%= encodeURIComponent(segment) %>"><%= version.variantName ?? version.versionLabel ?? 'Unspecified' %></a></td><td><code><%= version.canonicalReference %></code></td><td><%= version.status %></td><td><%= version.recordCount %></td></tr><% }) %></tbody></table></div>
<%~ include('partials/registry-table.eta', { records: it.records, emptyMessage: it.emptyMessage }) %><%~ include('partials/pagination.eta', it.pagination) %>
