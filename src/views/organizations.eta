<% layout('layout.eta') %><h1>Organizations</h1><p class="page-summary">Organizations associated with canonical models and their reported benchmark evaluation records.</p><p class="table-scroll-notice">Table may be scrolled horizontally on narrow displays.</p><div class="table-scroll" tabindex="0" aria-label="Organizations table"><table class="browse-table"><thead><tr><th>Organization</th><th>Prefix</th><th>BR Namespace</th><th>Records</th></tr></thead><tbody>
<% if (it.organizations.length === 0) { %><tr><td colspan="4" class="empty-state">No organizations are currently available.</td></tr><% } %>
<% it.organizations.forEach(function(organization) { %><tr><td><a href="/organizations/<%= encodeURIComponent(organization.slug) %>"><%= organization.name %></a></td><td><code><%= organization.providerPrefix %></code></td><td><code><%= organization.brNamespace %></code></td><td><%= organization.recordCount %></td></tr><% }) %>
</tbody></table></div>
