<% layout('layout.eta') %><h1>Sources</h1><p class="table-scroll-notice">Table may be scrolled horizontally on narrow displays.</p><div class="table-scroll" tabindex="0" aria-label="Sources table"><table class="browse-table"><thead><tr><th>Source</th><th>Type</th><th>Publisher</th><th>Published</th><th>Accessed</th></tr></thead><tbody>
<% if (it.sources.length === 0) { %><tr><td colspan="5" class="empty-state">No sources are currently available.</td></tr><% } %>
<% it.sources.forEach(function(source) { %><tr><td><% if (source.url !== null) { %><a href="<%= source.url %>" target="_blank" rel="noopener noreferrer"><%= source.title %></a><% } else { %><%= source.title %><% } %></td><td><%= source.sourceType %></td><td><%= source.publisher ?? 'Unknown' %></td><td><%= source.publishedDate ?? 'Unknown' %></td><td><%= source.accessedAt.toISOString() %></td></tr><% }) %>
</tbody></table></div>
