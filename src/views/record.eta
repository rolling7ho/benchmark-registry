<% layout('layout.eta') %>
<h1>BENCHMARK RECORD: <code class="identifier"><%= it.record.recordId %></code></h1>
<p>Benchmark scores may depend on benchmark version, evaluation configuration, model snapshot, and evaluator. Records sharing a benchmark name are not necessarily directly comparable.</p>

<h2>Record</h2>
<dl class="record-metadata"><dt>Record Identifier</dt><dd><code class="identifier"><%= it.record.recordId %></code></dd><dt>Record Status</dt><dd><%= it.record.recordStatus %></dd><dt>Created At</dt><dd><%= it.record.createdAt.toISOString() %></dd><dt>Updated At</dt><dd><%= it.record.updatedAt.toISOString() %></dd><dt>Superseded By</dt><dd><% if (it.record.supersededByRecordId !== null) { %><a href="/records/<%= encodeURIComponent(it.record.supersededByRecordId) %>"><code class="identifier"><%= it.record.supersededByRecordId %></code></a><% } else { %>Not applicable<% } %></dd></dl>

<h2>Model</h2>
<dl class="record-metadata"><dt>Official Model Name</dt><dd><%= it.record.modelName %></dd><dt>Model Identifier</dt><dd><a href="/models/<%= encodeURIComponent(it.record.modelIdentifier) %>"><code><%= it.record.modelIdentifier %></code></a></dd><dt>Organization</dt><dd><%= it.record.modelOrganization %></dd><dt>Model Family</dt><dd><%= it.record.modelFamily ?? 'Unknown' %></dd><dt>Model Number</dt><dd><%= it.record.modelNumber ?? 'Unknown' %></dd><dt>Tier</dt><dd><%= it.record.modelTier ?? 'Unknown' %></dd><dt>Model Snapshot</dt><dd><%= it.record.snapshotReference ?? 'Unknown' %></dd><dt>Snapshot Label</dt><dd><%= it.record.snapshotLabel ?? 'Unknown' %></dd><dt>Provider Model Identifier</dt><dd class="overflow-value"><code><%= it.record.providerModelIdentifier ?? 'Unknown' %></code></dd><dt>Snapshot Date</dt><dd><%= it.record.snapshotDate ?? 'Unknown' %></dd></dl>

<h2>Benchmark</h2>
<dl class="record-metadata"><dt>Benchmark Family</dt><dd><%= it.record.benchmarkFamily %></dd><dt>Benchmark Version or Variant</dt><dd><%= it.record.benchmarkVariantName ?? it.record.benchmarkVersionLabel ?? 'Unknown' %></dd><dt>Benchmark Version Reference</dt><dd><code><%= it.record.benchmarkVersionReference %></code></dd><dt>Benchmark Organization</dt><dd><%= it.record.benchmarkOrganization ?? 'Unknown' %></dd><dt>Benchmark Status</dt><dd><%= it.record.benchmarkStatus %></dd></dl>

<h2>Result</h2>
<dl class="record-metadata"><dt>Metric</dt><dd><%= it.record.metricName %></dd><dt>Score</dt><dd><%= it.record.scoreDisplay %></dd><dt>Numeric Score</dt><dd><%= it.record.scoreValue ?? 'Unknown' %></dd><dt>Evaluation Date</dt><dd><%= it.record.evaluationDate ?? 'Unknown' %></dd><dt>Reported Date</dt><dd><%= it.record.reportedDate ?? 'Unknown' %></dd></dl>

<h2>Evaluation Context</h2>
<dl class="record-metadata wide-metadata"><dt>Configuration Reference</dt><dd><%= it.record.configurationUnspecified ? 'Unspecified' : it.record.configurationReference %></dd><dt>Shots</dt><dd><%= it.record.shots ?? 'Unknown' %></dd><dt>Reasoning Mode</dt><dd><%= it.record.reasoningMode ?? 'Unknown' %></dd><dt>Reasoning Effort</dt><dd><%= it.record.reasoningEffort ?? 'Unknown' %></dd><dt>Pass Count</dt><dd><%= it.record.passCount ?? 'Unknown' %></dd><dt>Agent Scaffold</dt><dd><%= it.record.agentScaffold ?? 'Unknown' %></dd><dt>Evaluation Harness</dt><dd><%= it.record.evaluationHarness ?? 'Unknown' %></dd><dt>Temperature</dt><dd><%= it.record.temperature ?? 'Unknown' %></dd><dt>Top P</dt><dd><%= it.record.topP ?? 'Unknown' %></dd><dt>Max Output Tokens</dt><dd><%= it.record.maxOutputTokens ?? 'Unknown' %></dd><dt>System Prompt Description</dt><dd><%= it.record.systemPromptDescription ?? 'Unknown' %></dd><dt>Additional Configuration</dt><dd><pre class="configuration-value"><%= it.record.additionalConfigurationDisplay %></pre></dd></dl>

<h2>Source and Reporting</h2>
<dl class="record-metadata"><dt>Primary Source</dt><dd><% if (it.record.sourceUrl !== null) { %><a href="<%= it.record.sourceUrl %>" target="_blank" rel="noopener noreferrer"><%= it.record.sourceTitle ?? 'Untitled source' %></a><% } else { %><%= it.record.sourceTitle ?? 'Untitled source' %><% } %></dd><dt>Source Type</dt><dd><%= it.record.sourceType %></dd><dt>Publisher</dt><dd><%= it.record.sourcePublisher ?? 'Unknown' %></dd><dt>Source Published Date</dt><dd><%= it.record.sourcePublishedDate ?? 'Unknown' %></dd><dt>Source Accessed At</dt><dd><%= it.record.sourceAccessedAt.toISOString() %></dd><dt>Report Type</dt><dd><%= it.record.reportType %></dd><dt>Evaluator</dt><dd><%= it.record.evaluatorName %></dd><dt>Evaluator Type</dt><dd><%= it.record.evaluatorType %></dd></dl>
<% ['SUPPORTING', 'CORRECTION', 'ARCHIVE'].forEach(function(role) { const sources = it.record.additionalSources.filter(function(source) { return source.role === role; }); if (sources.length > 0) { %><h3><%= role === 'SUPPORTING' ? 'Supporting Sources' : role === 'CORRECTION' ? 'Correction Sources' : 'Archived Copies' %></h3><ul><% sources.forEach(function(source) { %><li><% if (source.url !== null) { %><a href="<%= source.url %>" target="_blank" rel="noopener noreferrer"><%= source.title ?? 'Untitled source' %></a><% } else { %><%= source.title ?? 'Untitled source' %><% } %></li><% }) %></ul><% } }) %>

<h2>Provenance</h2>
<div class="table-scroll" tabindex="0" aria-label="Record provenance table"><table class="provenance-table"><thead><tr><th>Date</th><th>Event</th><th>Source</th><th>Details</th></tr></thead><tbody><% it.record.provenance.forEach(function(event) { %><tr><td><%= event.createdAt.toISOString() %></td><td><%= event.label %></td><td><% if (event.sourceUrl !== null) { %><a href="<%= event.sourceUrl %>" target="_blank" rel="noopener noreferrer"><%= event.sourceTitle ?? 'Source' %></a><% } else { %><%= event.sourceTitle ?? '—' %><% } %></td><td><%= event.publicDetails ?? '—' %></td></tr><% }) %></tbody></table></div>

<h2>Record Status</h2>
<p>This record is <strong><%= it.record.recordStatus %></strong>. Registry identifiers remain reserved when record status changes.</p>
